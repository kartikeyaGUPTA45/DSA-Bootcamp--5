//Problem Link: https://www.geeksforgeeks.org/problems/segregate-0s-and-1s5106/1

//Solution: 
class Solution {
    void segregate0and1(int[] arr) {
        // code here
        int i=0,j=0;
        while(i < arr.length) {
            if (arr[i] == 0) {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
                
                i++;
                j++;
            } else {
                i++;
            }
        }
    }
}
